# ── Banco de dados (Supabase) ───────────────────────────────────────────────
# URL do pooler (Transaction Mode) — usada em runtime pelo app
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# URL direta — usada pelo Prisma para rodar migrations
DIRECT_URL="postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres"

# ── Autenticação ─────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria-em-producao"
JWT_EXPIRES_IN="7d"

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# URL do frontend no Vercel (sem barra no final)
# Aceita múltiplas origens separadas por vírgula
CORS_ORIGIN="https://SEU-PROJETO.vercel.app"

# ── Dados da empresa (aparecem no PDF dos orçamentos) ────────────────────────
COMPANY_NAME="JSN Pintura Eletrostática"
COMPANY_PHONE="(11) 00000-0000"
COMPANY_EMAIL="contato@jsn.com.br"
COMPANY_WEBSITE="www.jsn.com.br"
COMPANY_ADDRESS="Rua das Peças, 100 - São Paulo/SP"
